# ─── Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=bakery_platform

# ─── App ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Razorpay (optional) ─────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64char_string

# ─── Public API URL (set to your domain in production) ───
NEXT_PUBLIC_API_URL=https://rainbowbakes.in
