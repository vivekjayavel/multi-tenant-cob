NODE_ENV=development
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=bakery_platform
JWT_SECRET=minimum_32_char_random_string_change_this_now
JWT_EXPIRES_IN=7d
SUPERADMIN_SECRET=minimum_32_char_superadmin_secret_change_this
SUPERADMIN_JWT_SECRET=different_32_char_string_from_jwt_secret
SUPERADMIN_DOMAIN=manage.yourdomain.com
ENCRYPTION_KEY=64_hex_characters_exactly_32_bytes_change_this_now_pad
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_email_password
SMTP_FROM_NAME=Bakery Platform
SMTP_FROM_EMAIL=noreply@yourdomain.com
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
ABANDON_TIMEOUT_MINUTES=60
LOG_LEVEL=info
