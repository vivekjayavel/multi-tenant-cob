{
  "name": "bakery-platform",
  "version": "1.0.0",
  "description": "Multi-tenant bakery SaaS platform",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0 <20.0.0"
  },
  "scripts": {
    "dev": "node -e \"process.env.NODE_ENV='development'; require('./server.js')\"",
    "build": "next build frontend",
    "start": "node -e \"process.env.NODE_ENV='production'; require('./server.js')\"",
    "backup": "node scripts/backup.js",
    "backup:weekly": "node scripts/backup.js --weekly",
    "backup:verify": "node scripts/verify-backup.js",
    "backup:verify:all": "node scripts/verify-backup.js --all",
    "restore": "node scripts/restore.js --latest",
    "encrypt:secrets": "node scripts/encrypt-secrets.js",
    "encrypt:secrets:dry-run": "node scripts/encrypt-secrets.js --dry-run",
    "encrypt:secrets:verify": "node scripts/encrypt-secrets.js --verify",
    "security:verify": "node scripts/verify-file-security.js",
    "release:abandoned": "node scripts/release-abandoned-orders.js"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "express": "^4.18.3",
    "mysql2": "^3.9.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "razorpay": "^2.9.4",
    "nodemailer": "^6.9.13",
    "axios": "^1.6.8",
    "framer-motion": "^11.1.0",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "morgan": "^1.10.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "lru-cache": "^10.2.2",
    "node-cron": "^3.0.3",
    "slugify": "^1.6.6",
    "sharp": "^0.33.3",
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.3",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38"
  }
}